#!/usr/bin/env python3
"""Launcher: runs archsetup from this source checkout."""

import sys
from pathlib import Path

_ROOT = Path(__file__).resolve().parent
sys.path.insert(0, str(_ROOT / "src"))

# Prefer the project venv (development convenience) when textual is not
# available in the system Python.
_VENV_SITE = sorted((_ROOT / ".venv" / "lib").glob("python*/site-packages"))
try:
    import textual  # noqa: F401
except ModuleNotFoundError:
    if _VENV_SITE:
        sys.path.insert(0, str(_VENV_SITE[-1]))

from archsetup.__main__ import main

sys.exit(main())
